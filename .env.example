# ──────────────────────────────────────────────
# Text-to-Video Studio — Environment Configuration
# Copy this file to .env and customize
# ──────────────────────────────────────────────

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# AI Model
MODEL_ID=playgroundai/playground-v2-1024px-aesthetic
DEVICE=cuda
TORCH_DTYPE=float16

# Generation Defaults
DEFAULT_SCENE_DURATION=3.0
DEFAULT_NUM_INFERENCE_STEPS=30
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_RESOLUTION=768
MAX_SENTENCES=20
VIDEO_FPS=24

# Authentication — CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-this-now
ACCESS_TOKEN_EXPIRE_MINUTES=1440
